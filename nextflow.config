/*
========================================================================================
    ONT / HYBRID BACTERIAL WGS PIPELINE CONFIG
========================================================================================
*/

params {

    // El archivo que controla todo
    samplesheet = "$projectDir/samplesheet.csv"
    
    // La carpeta base donde están las subcarpetas de los barcodes
    reads_dir   = "$projectDir/data"
    
    outdir      = "$projectDir/results"
    input       = null
    mode        = null
    help        = false

    assemble = [
        circular : true
    ]

    hybrid = [
        short_inputs : "$projectDir/data/in/short/*_{1,2}.fastq.gz"
    ]

    
    enable_reports = true
    min_length = 1000
    genome_size = 5500000
    target_cov  = 100
    medaka_model = "r1041_e82_400bps_sup_v5.2.0"
    
    


    
}


process {
    
    withName: CAT_READS         { container = 'debian:stable-slim' }
    withName: 'NANOPLOT.*'      { container = 'quay.io/staphb/nanoplot:1.41.6' }
    withName: FILTLONG          { container = 'quay.io/staphb/filtlong:0.3.1' }
    withName: PORECHOP          { container = 'quay.io/staphb/porechop:0.2.4' }
    withName: NANOCOMP          { container = 'quay.io/biocontainers/nanocomp:1.25.6--pyhdfd78af_0' }
    withName: SEQKIT_STATS      { container = 'quay.io/biocontainers/seqkit:2.6.1--h9ee0642_0' }
    withName: SUBSAMPLING       { container = 'quay.io/staphb/filtlong:0.3.1' }
    withName: FLYE              { container = 'quay.io/staphb/flye:2.9.6' }
    withName: RACON             { container = 'quay.io/staphb/racon:1.5.0-minimap2' }
    withName: MEDAKA            { container = 'quay.io/staphb/medaka:2.2.0' }
    withName: DNAAPLER          { container = 'quay.io/staphb/dnaapler:1.3.0' }
    withName: QUAST             { container = 'quay.io/staphb/quast:5.2.0' }
    
        
    withLabel: 'process_low' {
        cpus = 2
        memory = '4 GB'
    }
    withLabel: 'process_medium' {
        cpus = 4
        memory = '16 GB'
    }
    withLabel: 'process_high' {
        cpus = 8
        memory = '64 GB'
    }

}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${projectDir}/.singularity_cache"
    }
    conda {
        conda.enabled = true
        // Opcional: especificar canal
        process.conda = 'bioconda::nanoplot bioconda::filtlong bioconda::porechop bioconda::nanocomp'
    }
}