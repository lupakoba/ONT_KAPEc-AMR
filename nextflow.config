/*
========================================================================================
    ONT / HYBRID BACTERIAL WGS PIPELINE CONFIG
========================================================================================
*/

params {
    
    mode            = 'assembly'
    help            = false
        
    samplesheet     = "${projectDir}/samplesheet.csv"
    reads_dir       = "$projectDir/data"
    short_inputs    = "$projectDir/data"
    outdir          = "$projectDir/results"

    min_length      = 1000
    genome_size     = 5500000
    target_cov      = 100
    medaka_model    = "dna_r10.4.1_e8.2_400bps_sup@v4.3.0"
    enable_reports  = true

    
    assemble {
        circular    = true
    }

    
    checkm2_db      = "${projectDir}/db/checkm2_db/CheckM2_database"
    bakta_db        = "${projectDir}/db/bakta_db/db-light"
    kaptive_db      = "${projectDir}/db/kaptive_db"
}

process {
    
    withName: CAT_READS         { container = 'debian:stable-slim' }
    withName: 'NANOPLOT.*'      { container = 'quay.io/biocontainers/nanoplot:1.47.1--pyhdfd78af_0' }  
    withName: FILTLONG          { container = 'quay.io/staphb/filtlong:0.3.1' }
    withName: PORECHOP          { container = 'quay.io/staphb/porechop:0.2.4' }
    withName: NANOCOMP          { container = 'quay.io/biocontainers/nanocomp:1.25.6--pyhdfd78af_0' }
    withName: SEQKIT_STATS      { container = 'quay.io/biocontainers/seqkit:2.6.1--h9ee0642_0' }
    withName: SUBSAMPLING       { container = 'quay.io/staphb/filtlong:0.3.1' }
    withName: FLYE              { container = 'quay.io/biocontainers/flye:2.9.5--py39h475c85d_2' }
    withName: RACON             { container = 'quay.io/staphb/racon:1.5.0-minimap2' }
    withName: MEDAKA            { container = 'quay.io/staphb/medaka:2.2.0' }
    withName: DNAAPLER          { container = 'quay.io/staphb/dnaapler:1.3.0' }
    withName: QUAST             { container = 'quay.io/staphb/quast:5.2.0' }
    withName: MLST              { container = 'quay.io/staphb/mlst:2.19.0' }
    
    withName: AMRFINDERPLUS     { container = 'staphb/ncbi-amrfinderplus:4.2.7-2026-03-24.1' }
    withName: ABRICATE_DB       { container = 'quay.io/staphb/abricate:1.0.0' }
    withName: ABRICATE_VF       { container = 'quay.io/staphb/abricate:1.0.0' }
    withName: MOB_RECON         { container = 'quay.io/biocontainers/mob_suite:3.1.9--pyhdfd78af_1' }
    withName: KAPTIVE           { container = 'quay.io/staphb/kaptive:3.2.0' }
    withName: ECTYPER           { container = 'quay.io/staphb/ectyper:2.0.0' }
    withName: PASTY             { container = 'quay.io/staphb/pasty:2.2.1' }

    withName: FASTP             { container = 'quay.io/staphb/fastp:1.1.0' }
    withName: FASTQC            { container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0' }
    withName: MULTIQC           { container = 'quay.io/biocontainers/multiqc:1.14--pyhdfd78af_0' }
    withName: UNICYCLER         { container = 'quay.io/staphb/unicycler:0.5.1' }

    
    withName: CHECKM2 {
        container = 'quay.io/staphb/checkm2:1.1.0'
        containerOptions = { workflow.profile.contains('singularity') ? "-B ${params.checkm2_db}:/db_checkm2" : "-v ${params.checkm2_db}:/db_checkm2" }
    }
    
    withName: BAKTA {
        container = 'quay.io/biocontainers/bakta:1.12.0--pyhdfd78af_0'
        containerOptions = { workflow.profile.contains('singularity') ? "-B ${params.bakta_db}:/db" : "-v ${params.bakta_db}:/db" }
    }

    
    withLabel: 'process_low' {
        cpus = 2
        memory = '4 GB'
        stageInMode = 'copy'
    }
    withLabel: 'process_medium' {
        cpus = 4
        memory = '16 GB'
        stageInMode = 'copy'
    }
    withLabel: 'process_high' {
        cpus = 8
        memory = '64 GB'
        stageInMode = 'copy'
    }
}

profiles {
    docker {
        docker.enabled    = true
        docker.runOptions = "-u \$(id -u):\$(id -g)"
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${projectDir}/.singularity_cache"
    }
    
}